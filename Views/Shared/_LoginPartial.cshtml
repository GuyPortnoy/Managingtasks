@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <span class="nav-user-email">@UserManager.GetUserName(User)</span>
    <form id="logoutForm" asp-area="Identity" asp-page="/Account/Logout"
          asp-route-returnUrl="@Url.Page("/Tasks/Index", new { area = "" })" method="post" style="margin:0;">
        <button id="logout" type="submit" class="btn-nav-logout">Logout</button>
    </form>
}
else
{
    <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Login</a>
    <a class="btn-primary-custom" asp-area="Identity" asp-page="/Account/Register">Register</a>
}
