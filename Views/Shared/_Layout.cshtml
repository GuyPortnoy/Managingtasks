<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – TaskFlow</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <nav class="navbar navbar-expand-sm">
        <div class="container-fluid d-flex align-items-center justify-content-between" style="height:60px;">
            <!-- Brand -->
            <a class="navbar-brand" asp-page="/Tasks/Index">
                <span class="brand-icon">✓</span>
                TaskFlow
            </a>

            <!-- Right side: auth links -->
            <div class="d-flex align-items-center gap-3">
                @await Html.PartialAsync("_LoginPartial")
            </div>
        </div>
    </nav>

    @RenderBody()

    <footer class="site-footer">
        &copy; @DateTime.Now.Year TaskFlow — Personal Task Manager
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
