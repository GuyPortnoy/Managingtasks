@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="glass-card mt-4">
            <div class="text-center mb-4">
                <span class="fs-1">🔑</span>
                <h2 class="fw-bold mt-2">Forgot Password?</h2>
                <p class="text-muted small">Enter your email address and we will generate a password reset link for you.</p>
            </div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                <!-- Email Input -->
                <div class="premium-form-group">
                    <label asp-for="Input.Email" class="premium-form-label">Email Address</label>
                    <input asp-for="Input.Email" class="premium-input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small mt-1 d-block"></span>
                </div>

                <!-- Reset Password Button -->
                <div class="mt-4">
                    <button type="submit" class="w-100 btn-premium justify-content-center pulse-hover">
                        📧 Send Reset Link
                    </button>
                </div>

                <div class="text-center mt-3">
                    <a asp-page="./Login" class="text-light-hover text-decoration-none small fw-semibold">
                        ⬅ Back to Login
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

