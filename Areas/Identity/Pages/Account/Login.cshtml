@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-logo">
            <div class="auth-logo-icon">✓</div>
            <span class="auth-logo-text">TaskFlow</span>
        </div>

        <h1 class="auth-title">Welcome back</h1>
        <p class="auth-subtitle">Sign in to access your tasks</p>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="validation-error"></div>

            <div class="form-group">
                <label class="form-label" asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" class="form-control-dark"
                       autocomplete="username" placeholder="you@example.com" />
                <span asp-validation-for="Input.Email" class="field-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" class="form-control-dark"
                       autocomplete="current-password" placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="field-error"></span>
            </div>

            <div class="form-group" style="display:flex; align-items:center; gap:0.5rem;">
                <input asp-for="Input.RememberMe" type="checkbox"
                       style="width:15px;height:15px;accent-color:var(--accent);" />
                <label asp-for="Input.RememberMe" class="form-label" style="margin:0;">Remember me</label>
            </div>

            <button id="login-submit" type="submit" class="btn-auth">Sign in</button>
        </form>

        <div class="auth-footer">
            <p>
                <a asp-page="./ForgotPassword" style="font-size:0.82rem; color:var(--text-muted);">Forgot password?</a>
            </p>
            <p style="margin-top:0.75rem;">
                Don't have an account?
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create one</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
