@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="glass-card mt-4">
            <div class="text-center mb-4">
                <span class="fs-1">🔐</span>
                <h2 class="fw-bold mt-2">Welcome Back</h2>
                <p class="text-muted small">Log in to manage your tasks and view your progress.</p>
            </div>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                <!-- Email Input -->
                <div class="premium-form-group">
                    <label asp-for="Input.Email" class="premium-form-label">Email Address</label>
                    <input asp-for="Input.Email" class="premium-input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small mt-1 d-block"></span>
                </div>

                <!-- Password Input -->
                <div class="premium-form-group">
                    <label asp-for="Input.Password" class="premium-form-label">Password</label>
                    <input asp-for="Input.Password" class="premium-input" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="text-danger small mt-1 d-block"></span>
                </div>

                <!-- Remember Me Checkbox -->
                <div class="mb-3 d-flex align-items-center justify-content-between">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" style="cursor: pointer; background-color: rgba(255, 255, 255, 0.05); border-color: var(--border-color);" />
                        <label asp-for="Input.RememberMe" class="form-check-label text-secondary small" style="cursor: pointer; user-select: none;">
                            Remember me
                        </label>
                    </div>
                    <div>
                        <a id="forgot-password" asp-page="./ForgotPassword" class="text-light-hover text-decoration-none small fw-semibold">Forgot password?</a>
                    </div>
                </div>

                <!-- Login Submit -->
                <div class="mt-4">
                    <button id="login-submit" type="submit" class="w-100 btn-premium justify-content-center pulse-hover">
                        <span>🔓</span> Log in
                    </button>
                </div>

                <div class="text-center mt-4 border-top pt-3" style="border-color: var(--border-color) !important;">
                    <p class="small text-muted mb-0">
                        Don't have an account yet? 
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-light-hover text-decoration-none fw-semibold">Register here</a>
                    </p>
                    <p class="small text-muted mt-2 mb-0">
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="text-light-hover text-decoration-none">Resend email confirmation</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

