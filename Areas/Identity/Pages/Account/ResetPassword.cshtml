@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="glass-card mt-4">
            <div class="text-center mb-4">
                <span class="fs-1">🔄</span>
                <h2 class="fw-bold mt-2">Reset Password</h2>
                <p class="text-muted small">Enter your account details and choose a new password.</p>
            </div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>
                <input asp-for="Input.Code" type="hidden" />

                <!-- Email Input -->
                <div class="premium-form-group">
                    <label asp-for="Input.Email" class="premium-form-label">Email Address</label>
                    <input asp-for="Input.Email" class="premium-input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small mt-1 d-block"></span>
                </div>

                <!-- Password Input -->
                <div class="premium-form-group">
                    <label asp-for="Input.Password" class="premium-form-label">New Password</label>
                    <input asp-for="Input.Password" class="premium-input" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="text-danger small mt-1 d-block"></span>
                </div>

                <!-- Confirm Password Input -->
                <div class="premium-form-group">
                    <label asp-for="Input.ConfirmPassword" class="premium-form-label">Confirm New Password</label>
                    <input asp-for="Input.ConfirmPassword" class="premium-input" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                </div>

                <!-- Reset Submit Button -->
                <div class="mt-4">
                    <button type="submit" class="w-100 btn-premium justify-content-center pulse-hover">
                        💾 Update Password
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

