@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="glass-card mt-4">
            <div class="text-center mb-4">
                <span class="fs-1">🚀</span>
                <h2 class="fw-bold mt-2">Create Account</h2>
                <p class="text-muted small">Sign up to start organizing and managing your tasks efficiently.</p>
            </div>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                <!-- Email Input -->
                <div class="premium-form-group">
                    <label asp-for="Input.Email" class="premium-form-label">Email Address</label>
                    <input asp-for="Input.Email" class="premium-input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small mt-1 d-block"></span>
                </div>

                <!-- Password Input -->
                <div class="premium-form-group">
                    <label asp-for="Input.Password" class="premium-form-label">Password</label>
                    <input asp-for="Input.Password" class="premium-input" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="text-danger small mt-1 d-block"></span>
                </div>

                <!-- Confirm Password Input -->
                <div class="premium-form-group">
                    <label asp-for="Input.ConfirmPassword" class="premium-form-label">Confirm Password</label>
                    <input asp-for="Input.ConfirmPassword" class="premium-input" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                </div>

                <!-- Register Submit -->
                <div class="mt-4">
                    <button id="registerSubmit" type="submit" class="w-100 btn-premium justify-content-center pulse-hover">
                        <span>✨</span> Register
                    </button>
                </div>

                <div class="text-center mt-3">
                    <p class="small text-muted mb-0">
                        Already have an account? 
                        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-light-hover text-decoration-none fw-semibold">Log in here</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

