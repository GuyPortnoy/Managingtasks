@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-logo">
            <div class="auth-logo-icon">✓</div>
            <span class="auth-logo-text">TaskFlow</span>
        </div>

        <h1 class="auth-title">Create your account</h1>
        <p class="auth-subtitle">Start managing your tasks today</p>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="validation-error"></div>

            <div class="form-group">
                <label class="form-label" asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" class="form-control-dark"
                       autocomplete="username" placeholder="you@example.com" />
                <span asp-validation-for="Input.Email" class="field-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" class="form-control-dark"
                       autocomplete="new-password" placeholder="Min. 6 characters" />
                <span asp-validation-for="Input.Password" class="field-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Input.ConfirmPassword">Confirm Password</label>
                <input asp-for="Input.ConfirmPassword" class="form-control-dark"
                       autocomplete="new-password" placeholder="Repeat password" />
                <span asp-validation-for="Input.ConfirmPassword" class="field-error"></span>
            </div>

            <button id="registerSubmit" type="submit" class="btn-auth">Create Account</button>
        </form>

        <div class="auth-footer">
            <p>
                Already have an account?
                <a asp-page="./Login">Sign in</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
