@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Forgot password confirmation";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="glass-card mt-4 text-center">
            <span class="fs-1">✉️</span>
            <h2 class="fw-bold mt-2">Check Your Email</h2>
            <p class="text-muted small">
                If the email address exists in our system, we have sent password reset instructions.
            </p>

            @if (!string.IsNullOrEmpty(Model.ResetUrl))
            {
                <div class="alert alert-info mt-4 text-start border-0" style="background: rgba(56, 189, 248, 0.08); color: var(--accent); border-radius: 8px;">
                    <h5 class="fw-bold fs-6 mb-2">💻 Local Development Mode</h5>
                    <p class="small mb-2" style="color: var(--text-secondary);">
                        Since no local email sender is configured, you can reset your password directly using the link below:
                    </p>
                    <a id="reset-password-link" href="@Model.ResetUrl" class="btn btn-sm btn-outline-premium w-100 justify-content-center mt-1">
                        🔑 Reset Password Link
                    </a>
                </div>
            }

            <div class="mt-4 border-top pt-3" style="border-color: var(--border-color) !important;">
                <a asp-page="./Login" class="text-light-hover text-decoration-none small fw-semibold">
                    ⬅ Return to Login
                </a>
            </div>
        </div>
    </div>
</div>

