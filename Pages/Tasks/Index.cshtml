@page
@model Managingtasks.Pages.Tasks.IndexModel
@using Managingtasks.Models.Enums

@{
    ViewData["Title"] = "My Tasks";
    var totalTasks = Model.Tasks.Count;
    var todoTasks = Model.Tasks.Count(t => t.Status == TaskItemStatus.ToDo);
    var inProgressTasks = Model.Tasks.Count(t => t.Status == TaskItemStatus.InProgress);
    var doneTasks = Model.Tasks.Count(t => t.Status == TaskItemStatus.Done);
}

<div class="row align-items-center mb-4">
    <div class="col-md-8">
        <h1 class="display-6 fw-bold">My Tasks Dashboard</h1>
        <p class="text-muted">Manage your tasks, track priorities, and update status in real-time.</p>
    </div>
    <div class="col-md-4 text-md-end">
        <a asp-page="/Tasks/Create" class="btn-premium pulse-hover">
            <span>➕</span> New Task
        </a>
    </div>
</div>

<!-- Stats Counter Section -->
<div class="row mb-4">
    <div class="col-md-3 col-sm-6 mb-3 mb-md-0">
        <div class="glass-card text-center p-3" style="margin-bottom: 0;">
            <div class="text-secondary small">Total Tasks</div>
            <div class="fs-2 fw-bold text-info">@totalTasks</div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3 mb-md-0">
        <div class="glass-card text-center p-3" style="margin-bottom: 0;">
            <div class="text-secondary small">To Do</div>
            <div class="fs-2 fw-bold text-light">@todoTasks</div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3 mb-md-0">
        <div class="glass-card text-center p-3" style="margin-bottom: 0;">
            <div class="text-secondary small">In Progress</div>
            <div class="fs-2 fw-bold text-warning">@inProgressTasks</div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="glass-card text-center p-3" style="margin-bottom: 0;">
            <div class="text-secondary small">Completed</div>
            <div class="fs-2 fw-bold text-success">@doneTasks</div>
        </div>
    </div>
</div>

<!-- Task Table Section -->
<div class="glass-card">
    @if (!Model.Tasks.Any())
    {
        <div class="text-center py-5">
            <span class="fs-1 d-block mb-3">📭</span>
            <h4 class="text-secondary">No tasks found.</h4>
            <p class="text-muted small">Create a new task to get started!</p>
            <a asp-page="/Tasks/Create" class="btn-premium btn-sm mt-2">Create First Task</a>
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <h5 class="mb-0 text-secondary">All Tasks</h5>
            <div class="d-flex align-items-center gap-2">
                <span class="text-secondary small">Sort by:</span>
                <select class="select-fast" onchange="window.location.search = '?sortBy=' + this.value;">
                    <option value="date_desc" selected="@(Model.CurrentSort == "date_desc")">Created (Newest first)</option>
                    <option value="date_asc" selected="@(Model.CurrentSort == "date_asc")">Created (Oldest first)</option>
                    <option value="priority_desc" selected="@(Model.CurrentSort == "priority_desc")">Priority (High to Low)</option>
                    <option value="priority_asc" selected="@(Model.CurrentSort == "priority_asc")">Priority (Low to High)</option>
                    <option value="status_asc" selected="@(Model.CurrentSort == "status_asc")">Status (To Do first)</option>
                    <option value="status_desc" selected="@(Model.CurrentSort == "status_desc")">Status (Done first)</option>
                </select>
            </div>
        </div>

        <div class="premium-table-container">
            <table class="premium-table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Description</th>
                        <th>
                            <a asp-page="/Tasks/Index" asp-route-sortBy="@Model.PrioritySort" class="sortable-header">
                                Priority
                                @if (Model.CurrentSort == "priority_asc")
                                {
                                    <span>▲</span>
                                }
                                else if (Model.CurrentSort == "priority_desc")
                                {
                                    <span>▼</span>
                                }
                                else
                                {
                                    <span class="text-muted opacity-50">⇅</span>
                                }
                            </a>
                        </th>
                        <th>
                            <a asp-page="/Tasks/Index" asp-route-sortBy="@Model.StatusSort" class="sortable-header">
                                Status
                                @if (Model.CurrentSort == "status_asc")
                                {
                                    <span>▲</span>
                                }
                                else if (Model.CurrentSort == "status_desc")
                                {
                                    <span>▼</span>
                                }
                                else
                                {
                                    <span class="text-muted opacity-50">⇅</span>
                                }
                            </a>
                        </th>
                        <th>
                            <a asp-page="/Tasks/Index" asp-route-sortBy="@Model.DateSort" class="sortable-header">
                                Created
                                @if (Model.CurrentSort == "date_asc")
                                {
                                    <span>▲</span>
                                }
                                else if (Model.CurrentSort == "date_desc" || string.IsNullOrEmpty(Model.CurrentSort))
                                {
                                    <span>▼</span>
                                }
                                else
                                {
                                    <span class="text-muted opacity-50">⇅</span>
                                }
                            </a>
                        </th>
                        <th>Updated</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in Model.Tasks)
                    {
                        <tr class="priority-row-@task.Priority.ToString().ToLower()">
                            <td class="fw-semibold text-white">@task.Title</td>
                            <td class="text-secondary" style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                @(string.IsNullOrEmpty(task.Description) ? "-" : task.Description)
                            </td>
                            <td>
                                @if (task.Priority == TaskPriority.High)
                                {
                                    <span class="badge-priority badge-priority-high">🔥 High</span>
                                }
                                else if (task.Priority == TaskPriority.Medium)
                                {
                                    <span class="badge-priority badge-priority-medium">⚡ Medium</span>
                                }
                                else
                                {
                                    <span class="badge-priority badge-priority-low">❄️ Low</span>
                                }
                            </td>
                            <td>
                                <form method="post" asp-page-handler="Edit" class="fast-status-form">
                                    <input type="hidden" name="id" value="@task.Id" />
                                    <select name="status" class="select-fast">
                                        <option value="ToDo" selected="@(task.Status == TaskItemStatus.ToDo)">To Do</option>
                                        <option value="InProgress" selected="@(task.Status == TaskItemStatus.InProgress)">In Progress</option>
                                        <option value="Done" selected="@(task.Status == TaskItemStatus.Done)">Done</option>
                                    </select>
                                    <button type="submit" class="btn-fast-save">Save</button>
                                </form>
                            </td>
                            <td class="text-secondary small">@task.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="text-secondary small">@task.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-page="/Tasks/Edit" asp-route-id="@task.Id" class="btn-outline-premium py-1 px-2.5 btn-sm">
                                        ✏️ Edit
                                    </a>
                                    <form method="post" asp-page-handler="Delete" class="m-0" onsubmit="return confirm('Are you sure you want to delete this task?');">
                                        <input type="hidden" name="id" value="@task.Id" />
                                        <button type="submit" class="btn-danger-premium py-1 px-2.5 btn-sm">
                                            🗑️ Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>