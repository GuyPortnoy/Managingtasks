@page
@model Managingtasks.Pages.Tasks.IndexModel
@{
    ViewData["Title"] = "My Tasks";
}

<div class="page-wrapper">
    <div class="page-header">
        <div>
            <h1 class="page-title">My Tasks</h1>
            <p class="page-subtitle">Manage and track your personal task list</p>
        </div>
        <a asp-page="/Tasks/Create" class="btn-primary-custom">
            ＋ Add Task
        </a>
    </div>

    <div class="card-dark">
        @if (!Model.Tasks.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">📋</div>
                <h3>No tasks yet</h3>
                <p>Create your first task to get started.</p>
                <a asp-page="/Tasks/Create" class="btn-primary-custom">＋ Add Task</a>
            </div>
        }
        else
        {
            <table class="task-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Title</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in Model.Tasks)
                    {
                        <tr>
                            <td class="task-date-cell">@task.Id</td>
                            <td class="task-title-cell">@task.Title</td>
                            <td class="task-desc-cell">@(string.IsNullOrEmpty(task.Description) ? "—" : task.Description)</td>
                            <td>
                                <form method="post" asp-page-handler="edit" class="status-form">
                                    <input type="hidden" name="id" value="@task.Id" />
                                    <select name="status" class="status-select">
                                        <option value="ToDo"       selected="@(task.Status == TaskItemStatus.ToDo)">To Do</option>
                                        <option value="InProgress" selected="@(task.Status == TaskItemStatus.InProgress)">In Progress</option>
                                        <option value="Done"       selected="@(task.Status == TaskItemStatus.Done)">Done</option>
                                    </select>
                                    <button type="submit" class="btn-save-custom">Save</button>
                                </form>
                            </td>
                            <td class="task-date-cell">@task.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="task-actions-cell">
                                <form method="post" asp-page-handler="Delete">
                                    <input type="hidden" name="id" value="@task.Id" />
                                    <button type="submit" class="btn-danger-custom"
                                            onclick="return confirm('Delete this task?')">
                                        🗑 Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>